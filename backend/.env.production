# Production Environment
NODE_ENV=production
PORT=5000

# Database
DB_HOST=your_railway_or_supabase_host
DB_PORT=3306
DB_NAME=incha_allah_prod
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your_super_secure_jwt_secret_key_min_32_chars

# Email
ADMIN_EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
ADMIN_EMAIL=admin@incha-allah.com

# Frontend URL
FRONTEND_URL=https://incha-allah-v2.vercel.app
