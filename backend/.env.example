# 🔒 CONFIGURATION PRODUCTION - RENDER + RAILWAY/SUPABASE
# Copie ce fichier en .env et complète avec tes valeurs

# Environment
NODE_ENV=production
PORT=5000

# 🗄️ DATABASE (Railway, Supabase, ou Planetscale)
DB_HOST=your-db-host.railway.app
DB_PORT=3306
DB_NAME=incha_allah_prod
DB_USER=root
DB_PASSWORD=your_secure_password

# 🔐 SECURITY
JWT_SECRET=generate_me_with_node_random_bytes_32_chars_minimum

# 📧 EMAIL NOTIFICATIONS
ADMIN_EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_specific_password_not_real_password
ADMIN_EMAIL=admin@incha-allah.com

# 🌐 URLS
FRONTEND_URL=https://incha-allah-v2.vercel.app

# 📞 WHATSAPP (optionnel)
WHATSAPP_PHONE=+227XXXXXXXX
