{
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/dist",
    "framework": "vite",
    "env": {
        "VITE_APP_NAME": "Kanari Service",
        "VITE_APP_VERSION": "1.0.0",
        "VITE_API_URL": "https://newvision-backend.onrender.com"
    },
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "redirects": [
        {
            "source": "/(.*)",
            "destination": "/index.html",
            "statusCode": 200
        }
    ]
}