{
    "buildCommand": "npm run build",
    "outputDirectory": "frontend/dist",
    "framework": "vite",
    "env": {
        "VITE_API_URL": "@vite_api_url",
        "VITE_APP_NAME": "Incha-Allah",
        "VITE_APP_VERSION": "1.0.0"
    },
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "redirects": [
        {
            "source": "/(.*)",
            "destination": "/index.html",
            "statusCode": 200
        }
    ]
}